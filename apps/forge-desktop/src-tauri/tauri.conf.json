{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge OS",
  "version": "0.1.0",
  "identifier": "com.sarthak.forgeos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Forge OS",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Autonomous software engineering OS",
    "longDescription": "Forge OS — persistent autonomous SWE runtime with event-sourced mission DAGs."
  }
}
